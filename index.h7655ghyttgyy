<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, maximum-scale=1.0">
    <title>ISKCON Hadapsar</title>
    
    <!-- Bootstrap & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>
    
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700&family=Poppins:wght@300;400;600&family=Dancing+Script:wght@700&family=Noto+Sans+Devanagari:wght@400;700&display=swap" rel="stylesheet">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    
    <style>
        /* =========================================
           🛠️ PREMIUM STYLES (EXTREME UI/UX UPGRADE & ANIMATIONS)
           ========================================= */
        :root {
            --primary: #FF9933;       
            --secondary: #4a2c2a;     
            --bg-color: #FAFAFA;      
            --card-bg: #ffffff;       
            --text-color: #2b2b2b;       
            --logo-size: 42px;         
            --text-img-height: 46px;   
            --slider-height: 290px;
            --event-date-size: 2.8rem; 
            --event-text-size: 1.15rem; 
            --icon-size: 1.8rem;      
            --card-text-size: 0.75rem; 
            --ui-shadow: 0 4px 18px rgba(0, 0, 0, 0.05);
            --powerful-shadow: 0 10px 30px rgba(255, 153, 51, 0.25);
            --epic-shadow: 0 12px 35px rgba(216, 27, 96, 0.3);
            --transition-speed: 0.3s;
        }[data-theme="dark"] {
            --primary: #FF9933; 
            --secondary: #140804; 
            --bg-color: #121212; 
            --card-bg: #1e1e1e; 
            --text-color: #ececec;
            --ui-shadow: 0 4px 18px rgba(0, 0, 0, 0.4);
            --powerful-shadow: 0 10px 30px rgba(0, 0, 0, 0.6);
            --epic-shadow: 0 12px 35px rgba(216, 27, 96, 0.4);
        }

        body { background-color: var(--bg-color); font-family: 'Poppins', 'Noto Sans Devanagari', sans-serif; color: var(--text-color); transition: background-color var(--transition-speed), color var(--transition-speed); padding-bottom: 0; margin: 0; -webkit-tap-highlight-color: transparent; }
        
        a { text-decoration: none; color: var(--primary); }

        /* Sleek Navbar */
        .navbar { background: linear-gradient(90deg, #E65100, var(--primary), #FF7043); background-size: 200% auto; animation: gradientMove 4s ease infinite; box-shadow: 0 4px 15px rgba(255, 153, 51, 0.4); padding: 8px 0; z-index: 1040; }
        @keyframes gradientMove { 0% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } 100% { background-position: 0% 50%; } }

        .navbar .container-fluid { display: flex; align-items: center; justify-content: space-between; flex-wrap: nowrap !important; }
        .nav-left-group { display: flex; align-items: center; gap: 10px; flex-grow: 1; overflow: hidden; }
        .navbar-brand { display: flex; align-items: center; gap: 6px; margin: 0; padding: 0; text-decoration: none; }
        .nav-logo-img { width: var(--logo-size); height: var(--logo-size); border-radius: 50%; border: 2px solid white; flex-shrink: 0; object-fit: cover; box-shadow: 0 2px 8px rgba(0,0,0,0.4); }
        .brand-text-img { height: var(--text-img-height); width: auto; max-width: 190px; object-fit: contain; margin-top: 1px; filter: drop-shadow(0 2px 2px rgba(0,0,0,0.2)); }
        
        .notif-btn { font-size: 1.4rem; color: white; flex-shrink: 0; padding-left: 10px; transition: 0.2s; position: relative;}
        .notif-btn i { animation: gentleSwing 2s infinite ease-in-out; transform-origin: top center; display: inline-block; }
        @keyframes gentleSwing { 0% { transform: rotate(0deg); } 15% { transform: rotate(15deg); } 30% { transform: rotate(-10deg); } 45% { transform: rotate(5deg); } 60% { transform: rotate(0deg); } 100% { transform: rotate(0deg); } }
        .notif-btn:active { transform: scale(0.85); }

        /* TICKER */
        .mantra-ticker { background-color: #fff3e0; color: #d84315; padding: 6px 0; overflow: hidden; white-space: nowrap; display: flex; align-items: center; border-bottom: 2px solid rgba(255, 153, 51, 0.3); font-family: 'Cinzel', serif; font-weight: 800; font-size: 0.85rem; box-shadow: inset 0 -3px 8px rgba(0,0,0,0.03); letter-spacing: 0.5px; }[data-theme="dark"] .mantra-ticker { background-color: #2e1503; color: #ffb74d; border-bottom: 2px solid rgba(255, 153, 51, 0.2); }
        .mantra-ticker-content { display: inline-block; white-space: nowrap; animation: textScroll 22s linear infinite; }
        .ticker-span { padding-right: 40px; }
        .ticker-span i { font-size:0.7rem; vertical-align:middle; color:var(--primary); margin:0 5px; animation: spinFast 4s linear infinite;}
        @keyframes textScroll { 0% { transform: translate3d(0, 0, 0); } 100% { transform: translate3d(-50%, 0, 0); } }
        @keyframes spinFast { 100% { transform: rotate(360deg); } }

        /* SIDEBAR */
        .offcanvas { background-color: var(--card-bg); color: var(--text-color); width: 280px !important; border-radius: 0 15px 15px 0; box-shadow: 10px 0 20px rgba(0,0,0,0.15) !important;}
        .offcanvas-header { border-bottom: 1px solid rgba(150, 150, 150, 0.1); padding-bottom: 15px; }
        .menu-item { padding: 12px 15px; display: flex; align-items: center; font-size: 0.95rem; font-weight: 500; color: var(--text-color); border-radius: 12px; margin-bottom: 5px; transition: 0.2s; cursor: pointer; text-decoration: none; overflow: hidden; }
        .menu-item:active { background: linear-gradient(90deg, rgba(255,153,51,0.2), transparent); color: var(--primary); transform: translateX(6px); font-weight:700;}
        .menu-item i { width: 32px; font-size: 1.1rem; color: var(--primary); text-align: left;}
        
        .pulse-heart { animation: pulseHeart 1.5s infinite; color: #ff1744 !important; filter: drop-shadow(0 0 5px rgba(255,23,68,0.5)); }
        @keyframes pulseHeart { 0% {transform: scale(1);} 50% {transform: scale(1.25);} 100% {transform: scale(1);} }
        .dev-contact-menu { background: rgba(216, 27, 96, 0.05); border: 1px dashed rgba(216, 27, 96, 0.3); }

        .lang-select { width: 100%; padding: 12px; border-radius: 12px; border: 1.5px solid rgba(255, 153, 51, 0.5); background: var(--bg-color); color: var(--text-color); margin-bottom: 15px; outline: none; font-weight: 700; cursor: pointer; transition: 0.3s; }
        .lang-select:focus { border-color: var(--primary); box-shadow: 0 0 10px rgba(255, 153, 51, 0.5); transform: scale(1.02);}

        /* SLIDER */
        .hero-slider { margin: 15px 16px; border-radius: 22px; overflow: hidden; box-shadow: var(--powerful-shadow); z-index: 1;}
        .carousel-item { height: var(--slider-height); background: var(--secondary); transition: transform .6s cubic-bezier(0.25, 0.8, 0.25, 1); position: relative; }
        .carousel-item img { object-fit: cover; height: 100%; width: 100%; filter: brightness(0.9); animation: zoomInImage 20s alternate infinite ease-in-out;}
        @keyframes zoomInImage { 0% {transform:scale(1);} 100% {transform:scale(1.15);} }
        
        .date-slide { height: 100%; width: 100%; display: flex; flex-direction: column; justify-content: center; align-items: center; background: linear-gradient(135deg, #FF6F00, #F57F17); color: white; text-align: center; padding: 15px; box-sizing: border-box; overflow:hidden;}
        .date-slide::after { content: ""; position: absolute; width: 250%; height: 250%; background: conic-gradient(from 0deg, transparent 0deg, rgba(255,255,255,0.1) 60deg, transparent 120deg); animation: rotateRays 15s linear infinite;}
        @keyframes rotateRays { from {transform: rotate(0deg);} to{transform: rotate(360deg);} }
        .date-slide h1 { font-family: 'Cinzel', serif; font-size: clamp(3.5rem, 12vw, 4.5rem); margin: 0; line-height: 1; text-shadow: 0 5px 15px rgba(0,0,0,0.4); z-index: 2; position:relative; }
        .date-slide p { font-size: clamp(0.85rem, 3vw, 1rem); margin: 5px 0 10px 0; text-transform: uppercase; letter-spacing: 2px; font-weight: 600; z-index: 2; position:relative; }
        .live-clock { font-family: 'monospace'; background: rgba(0,0,0,0.5); padding: 5px 18px; border-radius: 20px; font-weight: 700; border: 1px solid rgba(255,255,255,0.5); font-size: 1.2rem; letter-spacing: 1.5px; z-index: 2; position:relative; box-shadow: inset 0 2px 8px rgba(0,0,0,0.5); }
        .date-slide.has-event { padding: 20px 10px; }
        .date-slide.has-event h1 { font-size: clamp(2.2rem, 8vw, var(--event-date-size)); margin-bottom: 2px; }
        .date-slide.has-event .month-year { font-size: 0.85rem; margin: 0 0 5px 0; opacity: 0.95; }
        .date-slide.has-event .live-clock { font-size: 0.85rem; padding: 4px 12px; margin: 5px 0; }
        
        .ekadasi-alert { font-size: clamp(0.85rem, 3.5vw, var(--event-text-size)); font-weight: 700; line-height: 1.25; margin: 5px 0; padding: 10px 14px; background: rgba(255,255,255,0.25); border: 1px solid rgba(255,255,255,0.5); backdrop-filter: blur(8px); border-radius: 12px; width: 95%; max-width: 320px; word-wrap: break-word; z-index: 2; position:relative; text-shadow: 0 2px 5px rgba(0,0,0,0.5); box-shadow: 0 8px 20px rgba(0,0,0,0.25); }
        .ekadasi-btn { background: #fff; color: #d84315; padding: 6px 24px; border-radius: 25px; font-weight: 800; font-size: 0.85rem; text-decoration: none; animation: pulseBtnExtreme 1.2s infinite cubic-bezier(0.4, 0, 0.2, 1); display: inline-flex; align-items: center; justify-content:center; gap: 5px; margin-top: 5px; z-index: 2; position:relative; border: 2px solid white;}
        @keyframes pulseBtnExtreme { 0% { transform: scale(1); box-shadow: 0 4px 10px rgba(0,0,0,0.4); } 50% { transform: scale(1.08); box-shadow: 0 12px 25px rgba(255, 255, 255, 0.7); } 100% { transform: scale(1); box-shadow: 0 4px 10px rgba(0,0,0,0.4);} }

        /* FEATURES & QUOTES*/
        .feature-card { background: var(--card-bg); border-radius: 18px; padding: 15px 6px; text-align: center; box-shadow: var(--ui-shadow); display: flex; flex-direction: column; justify-content: center; align-items: center; transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); border: 1px solid rgba(150,150,150,0.1); cursor: pointer; position: relative; overflow: hidden; height: 100%; }
        .feature-card::after { content: ""; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%; background: linear-gradient(45deg, transparent 40%, rgba(255,255,255,0.4) 50%, transparent 60%); transform: rotate(45deg) translate(-100%, -100%); transition: none; z-index: 1; pointer-events: none; animation: cardShimmer 5s infinite; }[data-theme="dark"] .feature-card::after { background: linear-gradient(45deg, transparent 40%, rgba(255,255,255,0.08) 50%, transparent 60%); }
        @keyframes cardShimmer { 0%, 75% {transform: rotate(45deg) translate(-100%, -100%);} 100% {transform: rotate(45deg) translate(100%, 100%);} }
        .feature-card:active { transform: scale(0.92); border-color: var(--primary); box-shadow: var(--powerful-shadow);}
        .feature-card i { font-size: var(--icon-size); color: var(--primary); margin-bottom: 8px; z-index: 2; transition: 0.3s;}
        .feature-card:active i { transform: translateY(-3px) scale(1.1); color: #E65100; }
        .feature-card span { font-size: var(--card-text-size); font-weight: 700; line-height: 1.15; padding:0 3px; z-index: 2; text-align: center; }
        .live-dot { position: absolute; top: 12px; right: 28%; width: 10px; height: 10px; background-color: #ff1744; border-radius: 50%; box-shadow: 0 0 0 2px white, 0 0 10px red; animation: livePulseFast 0.8s infinite alternate; z-index: 2; }
        .new-badge { position: absolute; top: 0px; right: 0px; background: linear-gradient(90deg, #43a047, #66bb6a); color: white; padding: 4px 10px; border-radius: 0 16px 0 12px; font-size: 0.6rem; font-weight: 800; z-index: 2; letter-spacing:0.5px; box-shadow: 0 2px 6px rgba(67, 160, 71, 0.4);}
        @keyframes livePulseFast { 0% { opacity: 1; transform: scale(0.8); } 100% { opacity: 0.4; transform: scale(1.4); } }

        /* THE DAILY DIVINE THOUGHT BANNER - DYNAMICALLY UPDATED */
        .gita-daily-thought {
            background: linear-gradient(135deg, rgba(255, 153, 51, 0.08), rgba(255, 153, 51, 0.02)); border: 1.5px solid rgba(255, 153, 51, 0.2);
            border-left: 6px solid var(--primary); border-radius: 16px; margin: 12px 15px 18px 15px; padding: 14px 18px; 
            display: flex; flex-direction: column; justify-content: center; position: relative; overflow: hidden;
            box-shadow: 0 4px 15px rgba(255,153,51,0.06); transition: 0.3s;
        }[data-theme="dark"] .gita-daily-thought { background: linear-gradient(135deg, rgba(255, 153, 51, 0.08), #1e1e1e); }
        .gita-daily-thought::before {
            content:'\f10e'; font-family:'Font Awesome 6 Free'; font-weight:900; position:absolute; right: -5px; bottom: -15px; font-size: 4.5rem; color: var(--primary); opacity:0.07;
        }
        .g-t-head { display:flex; align-items:center; gap:6px; font-family:'Cinzel', serif; font-size:0.95rem; font-weight:800; color:var(--primary); margin-bottom:5px; z-index:2;}
        .g-t-text { font-size: 0.85rem; font-style: italic; font-weight: 500; color:var(--text-color); opacity: 0.9; line-height: 1.5; z-index:2;}
        
        /* EPIC LYRICS BOX - REDESIGNED TO COMPACT PREMIUM BUTTON */
        .master-lyrics-box { margin: 15px 15px 15px 15px; position: relative; border-radius: 16px; box-shadow: var(--epic-shadow); background: linear-gradient(135deg, #ad1457 0%, #D81B60 100%); overflow: hidden; display: flex; flex-direction: column; transition: transform 0.25s, box-shadow 0.25s;}
        .lyric-read-action { display: flex; align-items: center; text-decoration: none; padding: 12px 16px; position: relative; color: white; text-align: left; z-index: 2; gap: 14px;}
        .lyric-read-action:active { transform: scale(0.97); opacity: 0.95; }
        .float-letters { position: absolute; width: 100%; height: 100%; top: 0; left: 0; pointer-events: none; overflow: hidden; z-index:1; opacity: 0.25;}
        .fl-txt { position: absolute; font-family: 'Noto Sans Devanagari', serif; font-size: 1.6rem; font-weight: bold; text-shadow: 0 0 10px rgba(255,255,255,0.8); animation: flyUpLetters linear infinite;}
        .fl-1 { left: 10%; bottom: -20%; animation-duration: 4.5s; animation-delay: 0s;} .fl-2 { left: 60%; bottom: -30%; animation-duration: 5s; animation-delay: 1.5s; font-size:1.2rem;} .fl-3 { left: 85%; bottom: -15%; animation-duration: 4s; animation-delay: 0.5s;}
        @keyframes flyUpLetters { 0% {transform:translateY(0) scale(0.8); opacity:0;} 20%{opacity:1;} 80%{opacity:0.8;} 100% {transform:translateY(-80px) scale(1.3); opacity:0;} }
        
        .epic-book-icon { width: 44px; height: 44px; flex-shrink: 0; margin: 0; background: rgba(255,255,255,0.15); border-radius: 12px; display: flex; justify-content: center; align-items: center; font-size: 1.5rem; color: #ffeb3b; border: 1.5px solid rgba(255,235,59,0.5); box-shadow: 0 0 20px rgba(255, 235, 59, 0.4), inset 0 0 10px rgba(255, 255, 255, 0.2); position:relative; z-index:3; animation: heartbeatGlow 2.5s infinite alternate; transform: rotate(-5deg); }
        @keyframes heartbeatGlow { 0% {box-shadow: 0 0 10px rgba(255,235,59,0.3); transform: rotate(-3deg) scale(1);} 100%{box-shadow: 0 0 25px rgba(255,235,59,0.7); transform: rotate(-3deg) scale(1.08);} }
        
        .lyric-text-group { display: flex; flex-direction: column; flex-grow: 1; justify-content: center;}
        .lyric-title { font-family: 'Cinzel', serif; font-size: 1.05rem; font-weight: 800; margin: 0; line-height: 1.2; text-shadow: 0 2px 4px rgba(0,0,0,0.5); z-index: 3; position:relative; letter-spacing:0.5px;}
        .lyric-sub { font-size: 0.72rem; font-family: 'Poppins', sans-serif; font-weight: 500; margin-top: 3px; position:relative; z-index:3; color: rgba(255,255,255,0.95); opacity: 0.9;}
        
        .magic-flare { position: absolute; width: 60px; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.6), transparent); top:0; transform:skewX(-25deg); left: -100%; z-index: 1; animation: fastSweepFlare 3s infinite ease-in-out;}
        @keyframes fastSweepFlare { 0%,20%{left:-100%;} 100%{left: 200%;} }

        .lyrics-bottom-bar { background: rgba(0,0,0,0.25); border-top: 1px solid rgba(255,255,255,0.1); display:flex; padding: 8px 10px; flex-wrap:wrap; justify-content:center; align-items:center; gap: 8px; position: relative; z-index: 5;}
        .mini-meta-chip { background: rgba(255,255,255,0.1); border:1px solid rgba(255,255,255,0.3); border-radius: 12px; padding: 4px 10px; font-size:0.7rem; font-weight:600; color:white; text-decoration: none; transition: 0.2s; backdrop-filter:blur(3px); letter-spacing:0.5px; }
        .mini-meta-chip:active { background: white; color:#D81B60; transform:scale(0.9); border-color:white; }

        .section-header { display: flex; justify-content: space-between; align-items: center; margin: 20px 10px 15px 10px; }
        .section-title { font-family: 'Cinzel', 'Noto Sans Devanagari', serif; color: var(--text-color); font-size: 1.2rem; font-weight: 800; margin: 0; border-left: 6px solid var(--primary); padding-left: 10px; line-height:1.2; text-shadow:0 1px 1px rgba(0,0,0,0.05); }
        .see-all { font-size: 0.8rem; font-weight: 700; color: white; background: linear-gradient(45deg, var(--primary), #E65100); padding: 6px 14px; border-radius: 20px; display: flex; align-items: center; gap: 4px; transition: 0.3s; box-shadow: 0 4px 12px rgba(255, 153, 51, 0.4);}
        .see-all:active { transform: scale(0.9) translateX(3px); box-shadow:none;}

        .h-scroll { display: flex; overflow-x: auto; gap: 15px; padding: 4px 16px 20px 16px; scroll-behavior: smooth; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
        .h-scroll::-webkit-scrollbar { display: none; }
        .preview-card { flex-shrink: 0; min-width: 155px; width: 155px; background: var(--card-bg); border-radius: 18px; overflow: hidden; box-shadow: var(--ui-shadow); transition: transform 0.25s, box-shadow 0.25s; border: 1px solid rgba(150,150,150,0.08); position:relative;}
        .preview-card::after {content:''; position:absolute; top:0; left:0; width:100%; height:100%; background:linear-gradient(to top, rgba(0,0,0,0.25) 0%, transparent 50%); opacity:0; transition:0.3s; pointer-events:none;}
        .preview-card:active { transform: scale(0.92); box-shadow: var(--powerful-shadow);}
        .preview-card:active::after {opacity:1;}
        .preview-img { width: 100%; height: 115px; object-fit: cover; background:#eee;}
        .preview-info { padding: 12px; text-align: left; }
        .preview-title { font-size: 0.85rem; font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--text-color); }
        
        .address-box { background: var(--card-bg); border-radius: 20px; padding: 25px; box-shadow: var(--powerful-shadow); margin: 30px 15px 10px 15px; text-align: center; border: 1.5px solid rgba(255, 153, 51, 0.4); position: relative; overflow: hidden; scroll-margin-top: 100px; z-index: 1;}
        .address-box::before { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 7px; background: linear-gradient(90deg, #E65100, var(--primary), #E65100); background-size:200%; animation: gradientMove 3s infinite linear; }
        .address-text { font-size: 0.95rem; opacity: 0.8; margin-bottom: 20px; line-height: 1.6; font-weight:500;}
        .map-btn, .copy-btn { display: flex; align-items:center; justify-content:center; gap: 6px; width: 100%; padding: 14px; border-radius: 16px; font-weight: 800; font-size:0.9rem; transition:0.3s cubic-bezier(0.2, 0.8, 0.2, 1); border: none; cursor:pointer; }
        .map-btn { background: linear-gradient(135deg, var(--primary), #FF7043); color: white; box-shadow: 0 6px 18px rgba(255,153,51,0.35);}
        .map-btn:active { box-shadow:none; transform:scale(0.92); }
        .copy-btn { background: rgba(255, 153, 51, 0.1); color: var(--primary); border: 2.5px solid var(--primary); }
        .copy-btn:active { background: var(--primary); color:white; transform:scale(0.92);}
        
        .premium-footer { background: linear-gradient(180deg, #3d1b19 0%, #0d0402 100%); color: #ffcc80; padding-top: 0; position: relative; margin-top: 50px; text-align: center; overflow:hidden;}
        .footer-wave { width: 100%; height: auto; display: block; fill: #3d1b19; margin-top: -30px; filter: drop-shadow(0px -5px 10px rgba(0,0,0,0.15));}
        .premium-footer::after {content:''; position:absolute; bottom:-120px; left:50%; transform:translateX(-50%); width:350px; height:350px; background:radial-gradient(circle, rgba(255,153,51,0.25) 0%, transparent 60%); z-index:0; pointer-events:none;}
        
        .footer-content { padding: 10px 20px 40px 20px; position:relative; z-index:1;}
        .footer-logo-img { width: 120px; height: 120px; border-radius: 50%; border: 4px solid var(--primary); box-shadow: 0 0 35px rgba(255, 153, 51, 0.6); margin-bottom: 20px; background:#fff; transition:0.4s;}
        .footer-logo-img:hover {transform: rotate(5deg) scale(1.05);}
        .footer-mantra { font-family: 'Cinzel', 'Noto Sans Devanagari', serif; font-size: 1rem; color: #fff; margin-bottom: 30px; letter-spacing: 0.5px; line-height: 1.6; opacity: 0.95; text-shadow:0 3px 6px rgba(0,0,0,0.8);}
        .footer-links { margin-bottom: 30px; display:flex; flex-wrap:wrap; justify-content:center; gap: 15px; }
        .footer-links a { color: #ffb74d; font-size: 0.9rem; text-decoration: none; font-weight: 700; opacity: 0.9; position:relative; padding-bottom:3px;}
        .footer-links a::after {content: ''; position:absolute; bottom:0; left:0; width:100%; height:2px; background:#ffb74d; transform:scaleX(0); transition:0.3s cubic-bezier(0.2, 0.8, 0.2, 1);}
        .footer-links a:hover::after, .footer-links a:active::after {transform:scaleX(1);}
        .footer-social { display: flex; justify-content: center; gap: 18px; margin-bottom: 25px; }
        .f-icon { width: 50px; height: 50px; border-radius: 50%; background: rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center; color: white; transition:0.3s; font-size: 1.5rem; box-shadow: 0 4px 10px rgba(0,0,0,0.3); text-decoration: none;}
        .f-icon:active { background: linear-gradient(135deg, var(--primary), #E65100); transform:scale(0.85); border-color:transparent;}
        .footer-divider { height: 1.5px; background: linear-gradient(90deg, transparent, rgba(255,153,51,0.5), transparent); margin: 25px 0 15px 0; }
