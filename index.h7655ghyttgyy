                    let linkHtml = (type === 'notice' && noticeLink) ? `<a href="${noticeLink}" class="notice-btn">View Details <i class="fas fa-arrow-right" style="margin-left:4px;"></i></a>` : '';
                    
                    return `<div class="person-container ${compactClass}">
                                <div class="person-name ${fs}">${n}</div>
                                ${roleHtml}
                                ${addrHtml}
                                ${linkHtml}
                            </div>`;
                }).join('');

                allSlides.push({
                    type: type,
                    html: `
                    <div class="carousel-item" data-bs-interval="3500">
                        <div class="name-slide ${cssClass}">
